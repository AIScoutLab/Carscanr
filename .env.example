# CarScanr mobile env
# local: use http://localhost or your LAN IP
# preview/production: use a public HTTPS backend URL

EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Required for real Supabase-backed mobile auth in every environment.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Dev-only helper. Leave blank for preview/production builds.
EXPO_PUBLIC_PLAN_OVERRIDE=

# Build metadata for EAS / native iOS builds.
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_APP_NAME=CarScanr
EXPO_PUBLIC_IOS_BUNDLE_ID=com.yourname.carscanr
EXPO_PUBLIC_IOS_BUILD_NUMBER=1
