{
  "name": "car-identifier-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke:ocr": "tsx scripts/smokeGoogleVisionOcr.ts",
    "smoke:scan-route": "tsx scripts/smokeScanRouteOcr.ts",
    "export:offline-canonical": "tsx scripts/exportOfflineCanonical.ts",
    "seed": "tsx src/seed.ts",
    "test": "NODE_ENV=test AUTH_DEV_BYPASS_ENABLED=true node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@google-cloud/vision": "^5.3.5",
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.0.0",
    "pino": "^9.6.0",
    "sharp": "^0.33.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.13.13",
    "light-my-request": "^6.6.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
