# CarScanr backend env
# APP_ENV:
#   local      = laptop/dev mode, mock fallbacks allowed if explicitly enabled
#   preview    = public preview/staging deployment, no dev auth or mock fallbacks
#   production = public production deployment, no dev auth or mock fallbacks

PORT=4000
HOST=0.0.0.0
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info
CORS_ORIGIN=*
ALLOW_MOCK_FALLBACKS=true

# Required for real auth and persistence in preview/production.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Local-only dev bypass. Must stay false outside local development.
AUTH_DEV_BYPASS_ENABLED=false
AUTH_DEV_BYPASS_USER_ID=demo-user
AUTH_DEV_BYPASS_EMAIL=demo@example.com

UPLOAD_MAX_FILE_SIZE_BYTES=5242880
FREE_SCAN_LIMIT_PER_DAY=5
ABUSE_MAX_SCAN_ATTEMPTS_PER_10_MIN=10
SCAN_RATE_LIMIT_PER_MIN=5
UNLOCK_RATE_LIMIT_PER_10_MIN=10

# Vision provider
VISION_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o
OPENAI_VISION_TIMEOUT_MS=12000

# Vehicle data providers
VEHICLE_SPECS_PROVIDER=marketcheck
VEHICLE_VALUE_PROVIDER=marketcheck
VEHICLE_LISTINGS_PROVIDER=marketcheck
MARKETCHECK_API_KEY=your_marketcheck_api_key
MARKETCHECK_BASE_URL=https://api.marketcheck.com
MARKETCHECK_VALUE_RADIUS_MILES=100

# Provider cache
PROVIDER_SPECS_CACHE_TTL_HOURS=720
PROVIDER_VALUES_CACHE_TTL_HOURS=24
PROVIDER_LISTINGS_CACHE_TTL_HOURS=6
